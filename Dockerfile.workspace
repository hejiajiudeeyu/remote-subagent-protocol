FROM node:22-alpine AS deps
WORKDIR /app

COPY package.json package-lock.json ./
COPY apps/buyer-controller/package.json apps/buyer-controller/package.json
COPY apps/ops/package.json apps/ops/package.json
COPY apps/platform-console/package.json apps/platform-console/package.json
COPY apps/platform-api/package.json apps/platform-api/package.json
COPY apps/platform-console-gateway/package.json apps/platform-console-gateway/package.json
COPY apps/seller-controller/package.json apps/seller-controller/package.json
COPY apps/transport-relay/package.json apps/transport-relay/package.json
COPY packages/buyer-controller-core/package.json packages/buyer-controller-core/package.json
COPY packages/contracts/package.json packages/contracts/package.json
COPY packages/postgres-store/package.json packages/postgres-store/package.json
COPY packages/runtime-utils/package.json packages/runtime-utils/package.json
COPY packages/seller-runtime-core/package.json packages/seller-runtime-core/package.json
COPY packages/sqlite-store/package.json packages/sqlite-store/package.json
COPY packages/transports/email/package.json packages/transports/email/package.json
COPY packages/transports/emailengine/package.json packages/transports/emailengine/package.json
COPY packages/transports/gmail/package.json packages/transports/gmail/package.json
COPY packages/transports/local/package.json packages/transports/local/package.json
COPY packages/transports/relay-http/package.json packages/transports/relay-http/package.json

RUN npm ci --omit=dev

FROM node:22-alpine AS runtime
WORKDIR /app

ARG APP_PATH

COPY --from=deps /app/node_modules ./node_modules
COPY package.json package-lock.json ./
COPY apps ./apps
COPY packages ./packages
COPY scripts ./scripts

ENV NODE_ENV=production
WORKDIR /app/${APP_PATH}
CMD ["npm", "start"]
