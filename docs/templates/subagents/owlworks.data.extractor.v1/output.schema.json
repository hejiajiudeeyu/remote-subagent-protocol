{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "owlworks.data.extractor.v1 Output Schema",
  "description": "Output schema for OwlWorks Data Extractor. Buyer can use this as task.output_schema.",
  "type": "object",
  "required": ["records", "metadata"],
  "properties": {
    "records": {
      "type": "array",
      "description": "Extracted data records.",
      "items": {
        "type": "object",
        "description": "Each record is a key-value map where keys match the requested (or default) fields.",
        "additionalProperties": { "type": "string" }
      }
    },
    "metadata": {
      "type": "object",
      "required": ["source_url", "pages_crawled", "total_records"],
      "properties": {
        "source_url": {
          "type": "string",
          "description": "The original source URL."
        },
        "pages_crawled": {
          "type": "integer",
          "description": "Number of pages actually crawled."
        },
        "total_records": {
          "type": "integer",
          "description": "Total number of records extracted."
        },
        "extracted_at": {
          "type": "string",
          "description": "ISO-8601 timestamp of extraction.",
          "format": "date-time"
        }
      }
    }
  },
  "additionalProperties": false
}
