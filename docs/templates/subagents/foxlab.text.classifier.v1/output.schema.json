{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "foxlab.text.classifier.v1 Output Schema",
  "description": "Output schema for FoxLab Text Classifier. Buyer can use this as task.output_schema.",
  "type": "object",
  "required": ["label", "confidence"],
  "properties": {
    "label": {
      "type": "string",
      "description": "Predicted intent label (e.g. 'refund_request', 'shipping_inquiry', 'general_feedback')."
    },
    "confidence": {
      "type": "number",
      "description": "Model confidence score.",
      "minimum": 0,
      "maximum": 1
    },
    "secondary_labels": {
      "type": "array",
      "description": "Optional ranked list of alternative labels with scores.",
      "items": {
        "type": "object",
        "required": ["label", "confidence"],
        "properties": {
          "label": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    }
  },
  "additionalProperties": false
}
