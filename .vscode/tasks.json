{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Playground: Start (Foreground)",
      "type": "shell",
      "command": "python3",
      "args": [
        "scripts/playground.py",
        "start"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "clear": false
      },
      "problemMatcher": []
    },
    {
      "label": "Playground: Start (Daemon)",
      "type": "shell",
      "command": "python3",
      "args": [
        "scripts/playground.py",
        "daemon"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "clear": false
      },
      "problemMatcher": []
    },
    {
      "label": "Playground: Stop",
      "type": "shell",
      "command": "python3",
      "args": [
        "scripts/playground.py",
        "stop"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "clear": false
      },
      "problemMatcher": []
    },
    {
      "label": "Playground: Status",
      "type": "shell",
      "command": "python3",
      "args": [
        "scripts/playground.py",
        "status"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "clear": false
      },
      "problemMatcher": []
    }
  ]
}
