IMAGE_REGISTRY=ghcr.io/your-org
IMAGE_TAG=latest

BUYER_PORT=8081
SELLER_PORT=8082
RELAY_PORT=8090

PLATFORM_API_BASE_URL=http://host.docker.internal:8080
BUYER_PLATFORM_API_KEY=

BUYER_TRANSPORT_RECEIVER=buyer-controller
SELLER_TRANSPORT_RECEIVER=seller-local

ACK_DEADLINE_S=120
TIMEOUT_CONFIRMATION_MODE=ask_by_default
HARD_TIMEOUT_AUTO_FINALIZE=true
BUYER_CONTROLLER_POLL_INTERVAL_ACTIVE_S=5
BUYER_CONTROLLER_POLL_INTERVAL_BACKOFF_S=15
BUYER_CONTROLLER_INBOX_POLL_INTERVAL_MS=250
BUYER_CONTROLLER_EVENTS_SYNC_INTERVAL_MS=250

SELLER_ID=seller_local
SUBAGENT_IDS=local.subagent.v1
SELLER_SIGNING_PUBLIC_KEY_PEM=
SELLER_SIGNING_PRIVATE_KEY_PEM=
SELLER_MAX_HARD_TIMEOUT_S=300
SELLER_ALLOWED_TASK_TYPES=
SELLER_HEARTBEAT_INTERVAL_MS=30000
SELLER_INBOX_POLL_INTERVAL_MS=250
