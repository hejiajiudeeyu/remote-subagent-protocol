IMAGE_REGISTRY=ghcr.io/your-org
IMAGE_TAG=latest
PORT=8081
PLATFORM_API_BASE_URL=http://host.docker.internal:8080
PLATFORM_API_KEY=
TRANSPORT_BASE_URL=http://host.docker.internal:8090
TRANSPORT_RECEIVER=buyer-controller
ACK_DEADLINE_S=120
TIMEOUT_CONFIRMATION_MODE=ask_by_default
HARD_TIMEOUT_AUTO_FINALIZE=true
BUYER_CONTROLLER_POLL_INTERVAL_ACTIVE_S=5
BUYER_CONTROLLER_POLL_INTERVAL_BACKOFF_S=15
BUYER_CONTROLLER_INBOX_POLL_INTERVAL_MS=250
BUYER_CONTROLLER_EVENTS_SYNC_INTERVAL_MS=250
SQLITE_DATABASE_PATH=/data/buyer-controller.sqlite
DATABASE_URL=
